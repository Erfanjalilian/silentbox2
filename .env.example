# Copy to `.env.local` for local development (never commit secrets).

# Required — random string, min 16 characters (used to sign session cookies)
AUTH_SECRET=

# SMS.ir — server-side only
SMS_IR_API_KEY=

# Required for OTP: template ID from SMS.ir panel (ارسال سریع / Verify templates)
SMS_IR_VERIFY_TEMPLATE_ID=

# Optional: placeholder name in your template (must match panel), default Code
# SMS_IR_VERIFY_CODE_PARAM=Code
